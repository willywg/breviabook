# --- Secrets & local config (see ROADMAP §12: never commit API keys) ---
.env
.env.*
!.env.example
*.key
secrets/

# --- Job state / checkpoints / databases (never commit, ROADMAP §12) ---
*.sqlite
*.sqlite3
*.db
checkpoints/
.breviabook/
output/
out/

# --- Reference repos must stay OUTSIDE the tree (ROADMAP §14) ---
