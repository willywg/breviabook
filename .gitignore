TranslateBooksWithLLMs/
ollama-ebook-summary/
OllamaBook-Summarize/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Tooling caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Editors / OS / agent tooling ---
.vscode/
.idea/
*.swp
.DS_Store
.commandcode/

# --- Test artifacts (keep fixtures, ignore generated) ---
tests/output/
*.generated.*
